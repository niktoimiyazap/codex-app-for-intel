#!/usr/bin/env bash
set -euo pipefail

# launchd starts with a minimal PATH, so we pin common locations explicitly.
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"

APP_PATH="${APP_PATH:-/Applications/Codex.app}"
RES_DIR="$APP_PATH/Contents/Resources"
TARGET_MAIN="$RES_DIR/codex"
TARGET_ASAR="$RES_DIR/app.asar.unpacked/codex"
STATE_DIR="${STATE_DIR:-$HOME/.codex-intel-updater}"
BACKUP_DIR="$STATE_DIR/backups"
LOG_DIR="$STATE_DIR/logs"
LOG_FILE="$LOG_DIR/update.log"
LOCK_DIR="$STATE_DIR/.lock"
NPM_PACKAGE="${NPM_PACKAGE:-@openai/codex}"

mkdir -p "$BACKUP_DIR" "$LOG_DIR"

QUIET=0
if [[ "${1:-}" == "--quiet" ]]; then
  QUIET=1
fi

restore_needed=0
lock_held=0
backup_main=""
backup_asar=""

log() {
  local ts
  ts="$(date '+%Y-%m-%d %H:%M:%S')"
  local line="[$ts] $*"
  echo "$line" >>"$LOG_FILE"
  if [[ "$QUIET" -eq 0 ]]; then
    echo "$line"
  fi
}

fail() {
  log "ERROR: $*"
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "Missing required command: $1"
}

version_lt() {
  [[ "$1" == "$2" ]] && return 1
  local first
  first="$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -n1)"
  [[ "$first" == "$1" ]]
}

get_embedded_version() {
  "$TARGET_MAIN" --version 2>/dev/null | awk '{print $2}'
}

get_global_codex_version() {
  codex --version 2>/dev/null | awk '{print $2}'
}

resolve_source_binary() {
  local npm_root npm_prefix source

  npm_root="$(npm root -g)"
  source="$npm_root/$NPM_PACKAGE/node_modules/@openai/codex-darwin-x64/vendor/x86_64-apple-darwin/codex/codex"
  if [[ -x "$source" ]]; then
    echo "$source"
    return 0
  fi

  npm_prefix="$(npm prefix -g)"
  source="$npm_prefix/lib/node_modules/$NPM_PACKAGE/node_modules/@openai/codex-darwin-x64/vendor/x86_64-apple-darwin/codex/codex"
  if [[ -x "$source" ]]; then
    echo "$source"
    return 0
  fi

  source="/usr/local/lib/node_modules/$NPM_PACKAGE/node_modules/@openai/codex-darwin-x64/vendor/x86_64-apple-darwin/codex/codex"
  if [[ -x "$source" ]]; then
    echo "$source"
    return 0
  fi

  return 1
}

acquire_lock() {
  if mkdir "$LOCK_DIR" 2>/dev/null; then
    lock_held=1
  else
    log "Another updater run is in progress; exiting."
    exit 0
  fi
}

cleanup() {
  if [[ "$restore_needed" -eq 1 ]]; then
    log "Rolling back from backups..."
    if [[ -n "$backup_main" && -f "$backup_main" ]]; then
      cp -f "$backup_main" "$TARGET_MAIN"
    fi
    if [[ -n "$backup_asar" && -f "$backup_asar" ]]; then
      cp -f "$backup_asar" "$TARGET_ASAR"
    fi
    chmod 755 "$TARGET_MAIN" "$TARGET_ASAR" || true
    codesign --force --deep --sign - "$APP_PATH" >>"$LOG_FILE" 2>&1 || true
    log "Rollback complete."
  fi

  if [[ "$lock_held" -eq 1 ]]; then
    rmdir "$LOCK_DIR" >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

require_cmd uname
require_cmd npm
require_cmd codex
require_cmd codesign
require_cmd osascript
require_cmd awk
require_cmd sort

acquire_lock

[[ "$(uname -m)" == "x86_64" ]] || fail "This updater is intended for Intel/x86_64 macOS only."
[[ -d "$APP_PATH" ]] || fail "Codex.app not found at $APP_PATH"
[[ -x "$TARGET_MAIN" ]] || fail "Embedded binary not found: $TARGET_MAIN"
[[ -x "$TARGET_ASAR" ]] || fail "Embedded binary not found: $TARGET_ASAR"

embedded_ver="$(get_embedded_version || true)"
global_ver="$(get_global_codex_version || true)"
latest_ver="$(npm view "$NPM_PACKAGE" version 2>/dev/null || true)"

[[ -n "$embedded_ver" ]] || fail "Could not read embedded Codex version."
[[ -n "$global_ver" ]] || fail "Could not read global Codex version."

log "Embedded version: $embedded_ver"
log "Global CLI version: $global_ver"
if [[ -n "$latest_ver" ]]; then
  log "Latest npm version: $latest_ver"
else
  log "Latest npm version: unavailable (network or npm issue)."
fi

if [[ -n "$latest_ver" ]] && version_lt "$global_ver" "$latest_ver"; then
  log "Updating global $NPM_PACKAGE to $latest_ver..."
  if npm install -g "$NPM_PACKAGE@$latest_ver" >>"$LOG_FILE" 2>&1; then
    global_ver="$(get_global_codex_version || true)"
    log "Global CLI updated to: ${global_ver:-unknown}"
  else
    log "Global CLI update failed; continuing with currently installed version."
  fi
fi

source_bin="$(resolve_source_binary || true)"
[[ -n "$source_bin" ]] || fail "Could not locate x64 source binary in global $NPM_PACKAGE install."
[[ -x "$source_bin" ]] || fail "Resolved source binary is not executable: $source_bin"
source_ver="$("$source_bin" --version 2>/dev/null | awk '{print $2}')"
[[ -n "$source_ver" ]] || fail "Could not read source binary version: $source_bin"
log "Source binary: $source_bin ($source_ver)"

if [[ "$source_ver" == "$embedded_ver" ]]; then
  log "Codex.app already up to date for embedded CLI ($embedded_ver)."
  exit 0
fi

timestamp="$(date '+%Y%m%d-%H%M%S')"
backup_main="$BACKUP_DIR/codex.main.$timestamp"
backup_asar="$BACKUP_DIR/codex.asar.$timestamp"

log "Stopping Codex app before patch..."
osascript -e 'tell application "Codex" to quit' >/dev/null 2>&1 || true
sleep 1

log "Creating backups..."
cp -f "$TARGET_MAIN" "$backup_main"
cp -f "$TARGET_ASAR" "$backup_asar"
restore_needed=1

log "Replacing embedded binaries..."
cp -f "$source_bin" "$TARGET_MAIN"
cp -f "$source_bin" "$TARGET_ASAR"
chmod 755 "$TARGET_MAIN" "$TARGET_ASAR"

log "Re-signing app bundle (ad-hoc)..."
codesign --force --deep --sign - "$APP_PATH" >>"$LOG_FILE" 2>&1

new_ver="$(get_embedded_version || true)"
if [[ "$new_ver" != "$source_ver" ]]; then
  fail "Post-update validation failed (expected $source_ver, got ${new_ver:-unknown})."
fi

restore_needed=0
log "Update successful: embedded CLI $embedded_ver -> $new_ver"
log "Backups: $backup_main, $backup_asar"
