#!/usr/bin/env bash
set -euo pipefail

APP_PATH="${APP_PATH:-/Applications/Codex.app}"
RES_DIR="$APP_PATH/Contents/Resources"
TARGET_MAIN="$RES_DIR/codex"
TARGET_ASAR="$RES_DIR/app.asar.unpacked/codex"
LABEL="${LAUNCHD_LABEL:-com.codex-intel-updater}"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
STATE_DIR="${STATE_DIR:-$HOME/.codex-intel-updater}"
LOG_FILE="$STATE_DIR/logs/update.log"

printf 'Machine arch: %s\n' "$(uname -m)"
if [[ -d "$APP_PATH" ]]; then
  app_ver=$(/usr/libexec/PlistBuddy -c 'Print :CFBundleShortVersionString' "$APP_PATH/Contents/Info.plist" 2>/dev/null || echo "unknown")
  app_build=$(/usr/libexec/PlistBuddy -c 'Print :CFBundleVersion' "$APP_PATH/Contents/Info.plist" 2>/dev/null || echo "unknown")
  printf 'Codex.app: %s (build %s)\n' "$app_ver" "$app_build"
else
  echo "Codex.app: not found"
fi

if [[ -x "$TARGET_MAIN" ]]; then
  printf 'Embedded main: %s\n' "$("$TARGET_MAIN" --version 2>/dev/null || echo "unknown")"
  printf 'Embedded main arch: %s\n' "$(file "$TARGET_MAIN" | sed 's/.*: //')"
else
  echo "Embedded main: missing"
fi

if [[ -x "$TARGET_ASAR" ]]; then
  printf 'Embedded asar: %s\n' "$("$TARGET_ASAR" --version 2>/dev/null || echo "unknown")"
  printf 'Embedded asar arch: %s\n' "$(file "$TARGET_ASAR" | sed 's/.*: //')"
else
  echo "Embedded asar: missing"
fi

printf 'Global CLI: %s\n' "$(codex --version 2>/dev/null || echo "missing")"
printf 'NPM latest: %s\n' "$(npm view @openai/codex version 2>/dev/null || echo "unavailable")"

if [[ -f "$PLIST" ]]; then
  printf 'LaunchAgent plist: present (%s)\n' "$PLIST"
  if launchctl list | grep -q "$LABEL"; then
    echo "LaunchAgent state: loaded"
  else
    echo "LaunchAgent state: not loaded"
  fi
else
  echo "LaunchAgent plist: missing"
fi

if [[ -f "$LOG_FILE" ]]; then
  echo
  echo "Recent updater log:"
  tail -n 20 "$LOG_FILE"
fi
